APP_NAME="Denetfils API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8001
L5_SWAGGER_CONST_HOST=http://127.0.0.1:8000
L5_SWAGGER_GENERATE_ALWAYS=false
L5_FORMAT_TO_USE_FOR_DOCS=json

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=denetfils_api
DB_USERNAME=denetfils
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8001,localhost:8001

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=denetfils_api

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="support@denetfils.fr"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=
PAYPAL_RETURN_URL="${FRONTEND_URL}/checkout/paypal/return"
PAYPAL_CANCEL_URL="${FRONTEND_URL}/checkout/paypal/cancel"

GA4_MEASUREMENT_ID=
SENTRY_LARAVEL_DSN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SHIPPING_CURRENCY=EUR
SHIPPING_LABEL_DISK=local
SHIPPING_LABEL_DIRECTORY=private/shipping-labels
MONDIAL_RELAY_ENABLED=false
MONDIAL_RELAY_ENV=sandbox
MONDIAL_RELAY_ENSEIGNE=
MONDIAL_RELAY_PRIVATE_KEY=
MONDIAL_RELAY_BRAND_ID=
MONDIAL_RELAY_COUNTRY=FR
MONDIAL_RELAY_DEFAULT_LANGUAGE=FR
MONDIAL_RELAY_LABEL_FORMAT=A4
MONDIAL_RELAY_WIDGET_ENABLED=true
MONDIAL_RELAY_USE_OFFICIAL_WIDGET=true
MONDIAL_RELAY_MAP_PROVIDER=leaflet
MONDIAL_RELAY_API_ENDPOINT=https://api.mondialrelay.com/Web_Services.asmx
MONDIAL_RELAY_SENDER_NAME=
MONDIAL_RELAY_SENDER_ADDRESS=
MONDIAL_RELAY_SENDER_ADDRESS_2=
MONDIAL_RELAY_SENDER_POSTAL_CODE=
MONDIAL_RELAY_SENDER_CITY=
MONDIAL_RELAY_SENDER_COUNTRY=FR
MONDIAL_RELAY_SENDER_PHONE=
MONDIAL_RELAY_SENDER_EMAIL=
